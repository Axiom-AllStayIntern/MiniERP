// Minimal wrangler config for integration tests (Miniflare / local D1)
{
	"name": "smartfin-test",
	"compatibility_date": "2026-03-30",
	"compatibility_flags": ["nodejs_als"],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "smartfin-test",
			"database_id": "test-local-only",
			"migrations_dir": "drizzle/migrations"
		}
	]
}
