{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "smartfin",
	"compatibility_date": "2026-03-30",
	"compatibility_flags": [
		"nodejs_als"
	],
	"main": ".svelte-kit/cloudflare/_worker.js",
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "smartfin-db",
			"database_id": "e6494c48-4290-49d9-aac0-9398830baa9b",
			"migrations_dir": "drizzle/migrations"
		}
	],
	"r2_buckets": [
		{
			"binding": "R2",
			"bucket_name": "smartfin-files"
		}
	],
	"kv_namespaces": [
		{
			"binding": "KV",
			"id": "0dceb2c3f48145fea746b64b9c227a6b"
		}
	],
	"queues": {
		"producers": [
			{
				"binding": "OCR_QUEUE",
				"queue": "smartfin-ocr"
			}
		]
	},
	"vars": {
		"BETTER_AUTH_URL": "https://smartfin.smartfin.workers.dev",
		"LLM_PROVIDER": "external",
		"LLM_API_URL": "https://api.openai.com/v1/chat/completions",
		"OCR_PROMPT_VERSION": "v1"
	},
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	"workers_dev": true,
	"preview_urls": true
}