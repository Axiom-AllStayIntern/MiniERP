{
	"$schema": "./node_modules/wrangler/config-schema.json",
	// 部署名、绑定、默认非机密 vars。密钥与本地覆盖请用项目根 `.dev.vars`（勿提交），
	// 合并顺序：`vars` 与 `.dev.vars` 同名的键以 `.dev.vars` 为准。
	"name": "smartfin",
	"account_id": "c09bb2823904032b6ec648b23411f2e0",
	"compatibility_date": "2026-03-30",
	"compatibility_flags": [
		"nodejs_als"
	],
	"main": ".svelte-kit/cloudflare/_worker.js",
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "smartfin-db",
			"database_id": "208e1ed4-437f-4da5-93d7-7058debea5c8",
			"migrations_dir": "drizzle/migrations"
		}
	],
	"r2_buckets": [
		{
			"binding": "R2",
			"bucket_name": "smartfin-files"
		}
	],
	"kv_namespaces": [
		{
			"binding": "KV",
			"id": "fd0eca3363a3444daff52d1a35af69eb"
		}
	],
	"queues": {
		"producers": [
			{
			"binding": "OCR_QUEUE",
			"queue": "smartfin-ocr-queue"  
			}
		]
//		"consumers": [
//			{
//			"queue": "smartfin-ocr-queue",
//			"dead_letter_queue": "smartfin-ocr-queue-dlq"
//			}
//		]
	},
	"vars": {
		// 线上 Worker 默认站点；本地 localhost 时应用会按请求 origin 覆盖 auth 基地址。
		"BETTER_AUTH_URL": "https://smartfin.aki-wang.workers.dev",
		"EMAIL_FROM": "SmartFin <onboarding@resend.dev>",
		"LLM_PROVIDER": "heuristic",
		"WORKERS_AI_MODEL": "@cf/meta/llama-3.1-8b-instruct",
		"WORKERS_AI_VISION_MODEL": "@cf/meta/llama-3.2-11b-vision-instruct",
		"OCR_PROMPT_VERSION": "v1"
	},
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	// Workers AI 无本地模拟；`wrangler dev --local` 时必须显式 remote，否则会报 “Binding AI needs to be run remotely”
	"ai": { "binding": "AI", "remote": true },
	"workers_dev": true,
	"preview_urls": true
}