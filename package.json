{
	"name": "smartfin",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"lint": "tsc --noEmit",
		"test": "vitest run",
		"test:unit": "vitest run",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"dev": "vite dev",
		"dev:vite": "vite dev",
		"dev:cf": "npm run build && wrangler dev .svelte-kit/cloudflare/_worker.js --port 5173",
		"dev:cf:local": "npm run build && wrangler dev .svelte-kit/cloudflare/_worker.js --local --port 5173",
		"build": "vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check:modular-boundary": "node scripts/check-modular-boundary.mjs",
		"check:architecture-report": "node scripts/check-modular-boundary.mjs --report-only",
		"check": "npm run check:modular-boundary && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"gen": "wrangler types",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply smartfin-db --local",
		"db:migrate:remote": "wrangler d1 migrations apply smartfin-db --remote",
		"db:seed:local": "wrangler d1 execute smartfin-db --local --file drizzle/seeds/local-customers.sql",
		"db:seed:mock:local": "wrangler d1 execute smartfin-db --local --file drizzle/seeds/local-mock-full.sql",
		"db:test:mock:local": "npm run db:migrate:local && npm run db:seed:mock:local",
		"mobile": "npm --prefix mobile run start",
		"mobile:typecheck": "npm --prefix mobile run typecheck",
		"deploy:document-processor": "wrangler deploy --config workers/wrangler.document-processor.jsonc",
		"dev:document-processor": "wrangler dev --config workers/wrangler.document-processor.jsonc",
		"dev:cf:v4": "wrangler dev --env v4",
		"deploy:v4": "npm run build && wrangler deploy --env v4",
		"deploy:document-processor:v4": "wrangler deploy --config workers/wrangler.document-processor.jsonc --env v4",
		"db:migrate:remote:v4": "wrangler d1 migrations apply smartfin-db-v4 --remote"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.8.71",
		"@sveltejs/adapter-cloudflare": "^7.2.6",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@vitest/coverage-v8": "^3.2.4",
		"autoprefixer": "^10.4.27",
		"drizzle-kit": "^0.31.10",
		"postcss": "^8.5.8",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^3.4.19",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^3.2.4",
		"wrangler": "^4.90.1"
	},
	"dependencies": {
		"@fontsource/inter": "^5.2.8",
		"@thednp/dommatrix": "^3.0.4",
		"better-auth": "^1.5.6",
		"drizzle-orm": "^0.45.2",
		"fflate": "^0.8.2",
		"html2canvas": "^1.4.1",
		"jspdf": "^4.2.1",
		"lucide-svelte": "^1.0.1",
		"pdf-lib": "^1.17.1",
		"pdfjs-dist": "^5.6.205",
		"zod": "^4.3.6"
	}
}
